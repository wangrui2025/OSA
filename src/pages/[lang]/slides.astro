---
import Layout from '../../layouts/Layout.astro';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const lang = Astro.params.lang as 'en' | 'zh';
const title = lang === 'en' ? 'OSA — Echocardiography Segmentation (CVPR 2026)' : 'OSA — 超声心动图分割 (CVPR 2026)';
const description =
  lang === 'en'
    ? 'OSA: Orthogonalized State Update and Anatomical Prior-aware Feature Enhancement for Echocardiography Video Segmentation. CVPR 2026 presentation slides by Rui Wang, Shenzhen University.'
    : 'OSA：基于正交状态更新与解剖先验感知特征增强的超声心动图视频分割。CVPR 2026 报告幻灯片，深圳大学王锐。';
---
<Layout title={title} description={description} lang={lang} showFooter={false}>
  <!-- iframe wrapper: fixed height, overflow hidden so scaled iframe doesn't cause page scroll -->
  <div class="slides-viewport">
    <div class="slides-scaler" id="slides-scaler">
      <iframe
        id="slides-iframe"
        src={`${import.meta.env.BASE_URL}/slides.html`}
        title="OSA Slides"
        loading="lazy"
      ></iframe>
    </div>
  </div>

  <!-- Controls: fixed at bottom center -->
  <div class="controls">
    <span class="controls-label">Preview:</span>
    <span class="zoom-level" id="zoom-level">Fit</span>
    <div class="controls-group">
      <button id="zoom-out" title="Zoom out (−)">−</button>
      <button id="zoom-in" title="Zoom in (+)">+</button>
    </div>
    <button id="zoom-fit" class="active" title="Fit to window (0)">Fit</button>
    <div class="divider"></div>
    <button id="print-btn" title="Print / Save as PDF (P)">Print PDF</button>
  </div>
</Layout>

<style>
  html, body {
    overflow: hidden;
  }

  .slides-viewport {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    overflow: hidden;
    background: #0a0a0a;
  }

  .slides-scaler {
    width: 100%;
    height: 100%;
    transform-origin: top center;
  }

  iframe {
    width: 100%;
    height: 100%;
    border: 0;
    display: block;
  }

  /* Controls overlay */
  .controls {
    position: fixed;
    bottom: 1.25rem;
    left: 50%;
    transform: translateX(-50%);
    z-index: 200;
    display: flex;
    align-items: center;
    gap: 0.4rem;
    background: rgba(10, 10, 10, 0.88);
    backdrop-filter: blur(10px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 0.75rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.8rem;
    color: #e2e8f0;
    font-family: 'Inter', system-ui, sans-serif;
    box-shadow: 0 8px 32px rgba(0,0,0,0.5);
    white-space: nowrap;
  }

  .controls-label {
    color: #64748b;
    font-size: 0.72rem;
    margin-right: 0.2rem;
  }

  .zoom-level {
    min-width: 2.8rem;
    text-align: center;
    font-variant-numeric: tabular-nums;
    font-size: 0.78rem;
    color: #94a3b8;
  }

  .controls-group {
    display: flex;
    gap: 0.1rem;
  }

  .controls button {
    background: rgba(255, 255, 255, 0.07);
    border: 1px solid rgba(255, 255, 255, 0.09);
    border-radius: 0.375rem;
    color: #e2e8f0;
    cursor: pointer;
    font-size: 0.9rem;
    width: 2rem;
    height: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s, border-color 0.15s;
    font-family: inherit;
    line-height: 1;
  }

  .controls button:hover {
    background: rgba(255, 255, 255, 0.15);
    border-color: rgba(255, 255, 255, 0.2);
  }

  .controls button.active {
    background: rgba(134, 31, 65, 0.5);
    border-color: rgba(134, 31, 65, 0.8);
    color: #fda4af;
  }

  .divider {
    width: 1px;
    height: 1.4rem;
    background: rgba(255, 255, 255, 0.1);
    margin: 0 0.2rem;
  }

  #print-btn {
    width: auto;
    padding: 0 0.65rem;
    font-size: 0.75rem;
    gap: 0.3rem;
  }
</style>

<script>
  const scaler = document.getElementById('slides-scaler')!;
  const iframe = document.getElementById('slides-iframe') as HTMLIFrameElement;
  const zoomLevelEl = document.getElementById('zoom-level')!;
  const zoomInBtn = document.getElementById('zoom-in')!;
  const zoomOutBtn = document.getElementById('zoom-out')!;
  const zoomFitBtn = document.getElementById('zoom-fit')!;
  const printBtn = document.getElementById('print-btn')!;

  const zoomSteps = [0.2, 0.5, 0.75, 1.0, 1.25, 1.5, 2.0];
  let currentZoomIndex = -1; // -1 = fit

  function updateActiveBtn() {
    [zoomInBtn, zoomOutBtn, zoomFitBtn].forEach(b => b.classList.remove('active'));
  }

  function setZoom(index: number) {
    currentZoomIndex = index;
    if (index === -1) {
      scaler.style.transform = '';
      scaler.style.width = '';
      zoomLevelEl.textContent = 'Fit';
      zoomFitBtn.classList.add('active');
    } else {
      const z = zoomSteps[index];
      scaler.style.transform = `scale(${z})`;
      // Width must expand to accommodate scaled iframe so no clipping
      scaler.style.width = `${(100 / z)}%`;
      zoomLevelEl.textContent = `${Math.round(z * 100)}%`;
      zoomFitBtn.classList.remove('active');
    }
    updateActiveBtn();
  }

  zoomInBtn.addEventListener('click', () => {
    if (currentZoomIndex === -1) setZoom(0); // start at 20%
    else if (currentZoomIndex < zoomSteps.length - 1) setZoom(currentZoomIndex + 1);
  });

  zoomOutBtn.addEventListener('click', () => {
    if (currentZoomIndex === -1) setZoom(2); // start at 200% (zoom out)
    else if (currentZoomIndex > 0) setZoom(currentZoomIndex - 1);
    else if (currentZoomIndex === 0) setZoom(-1);
  });

  zoomFitBtn.addEventListener('click', () => setZoom(-1));

  printBtn.addEventListener('click', () => {
    const printWindow = window.open(iframe.src, '_blank');
    if (printWindow) {
      printWindow.addEventListener('load', () => {
        printWindow.print();
      });
    }
  });

  document.addEventListener('keydown', (e) => {
    if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;
    if (e.key === '+' || e.key === '=') { e.preventDefault(); zoomInBtn.click(); }
    if (e.key === '-') { e.preventDefault(); zoomOutBtn.click(); }
    if (e.key === '0') { e.preventDefault(); setZoom(-1); }
    if (e.key === 'p' || e.key === 'P') { e.preventDefault(); printBtn.click(); }
  });
</script>
