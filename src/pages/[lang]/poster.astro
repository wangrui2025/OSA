---
import Layout from '../../layouts/Layout.astro';
import { t } from '../../i18n/index.ts';

export function getStaticPaths() {
  return [{ params: { lang: 'en' } }, { params: { lang: 'zh' } }];
}

const lang = Astro.params.lang as 'en' | 'zh';
const title = t(lang, 'poster.title');
const description = t(lang, 'poster.description');
---
<Layout title={title} description={description} lang={lang} showFooter={false}>
  <iframe
    src={`${import.meta.env.BASE_URL}/poster.html`}
    class="w-full h-screen border-0"
    title="OSA Poster"
    loading="lazy"
  ></iframe>
</Layout>
