---
import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';
import katex from 'katex';
import 'katex/dist/katex.min.css';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
// __dirname is dist/.prerender/chunks/, so ../../.. gives project root
const projectRoot = path.resolve(__dirname, '../../../');
const srcPath = path.join(projectRoot, 'public/slides.src');
let html = fs.readFileSync(srcPath, 'utf-8');

function renderLatex(latex: string): string {
  const clean = latex.trim();
  return katex.renderToString(clean, { displayMode: true, throwOnError: false });
}

// 1. Pre-render formulas in katex-display spans
html = html.replace(
  /<span[^>]*class="[^"]*katex-display[^"]*"[^>]*>\$\$([\s\S]*?)\$\$\$<\/span>/g,
  (_: string, latex: string) => `<span class="katex-display katex-rendered">${renderLatex(latex)}</span>`
);

// 2. Pre-render remaining standalone $$
html = html.replace(/\$\$([\s\S]*?)\$\$/g, (_: string, latex: string) => renderLatex(latex));

// 3. Remove KaTeX CDN CSS
html = html.replace(/<link[^>]*href="[^"]*katex[^"]*"[^>]*>/gi, '');

// 4. Remove KaTeX CDN JS
html = html.replace(/<script[^>]*src="[^"]*(?:katex|auto-render)[^"]*"[^>]*><\/script>/gi, '');

// 5. Remove inline KaTeX rendering script
html = html.replace(
  /<script\b[^>]*>([\s\S]*?)<\/script>/gi,
  (match: string, content: string) => {
    if (/renderMathInElement|katex\.render|autoRender/.test(content)) {
      return '';
    }
    return match;
  }
);

// 6. Hard validation
if (/\$\$/.test(html)) {
  throw new Error('[ERROR] Residual unrendered $$ markers');
}
if (/<script[^>]src="[^"]*katex/i.test(html)) {
  throw new Error('[ERROR] Residual KaTeX JS reference');
}
---

<Fragment set:html={html} />
