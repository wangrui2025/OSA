---
import fs from 'fs';
import path from 'path';
import { fileURLToPath } from 'url';
import katex from 'katex';
import 'katex/dist/katex.min.css';

const __dirname = path.dirname(fileURLToPath(import.meta.url));
const projectRoot = path.resolve(__dirname, '../../../');
const srcPath = path.join(process.cwd(), 'public/slides.src');
let html = fs.readFileSync(srcPath, 'utf-8');

function renderLatex(latex: string): string {
  return katex.renderToString(latex.trim(), { displayMode: true, throwOnError: false });
}

// Step 1: Remove KaTeX CDN scripts/styles first (before formula replacement)
html = html.replace(/<link[^>]*href="[^"]*katex[^"]*"[^>]*>/gi, '');
html = html.replace(/<script[^>]*src="[^"]*(?:katex|auto-render)[^"]*"[^>]*><\/script>/gi, '');
html = html.replace(
  /<script\b[^>]*>([\s\S]*?)<\/script>/gi,
  (match: string, content: string) => {
    if (/renderMathInElement|katex\.render|autoRender/.test(content)) return '';
    return match;
  }
);

// Step 2: Pre-render formulas (source uses $$...$$ format inside katex-display spans)
html = html.replace(
  /<span[^>]*class="[^"]*katex-display[^"]*"[^>]*>\$\$([^$]+)\$\$/g,
  (_: string, latex: string) => {
    const rendered = renderLatex(latex);
    // KaTeX outputs katex-display span; strip it to avoid nesting
    const stripped = rendered.replace(/<span class="katex-display">/, '<span class="katex-rendered-inner">');
    return stripped;
  }
);

// Parse HTML: split head and body
const headMatch = html.match(/<head>([\s\S]*?)<\/head>/);
const bodyMatch = html.match(/<body>([\s\S]*?)<\/body>/);
const headContent = headMatch ? headMatch[1] : '';
const bodyContent = bodyMatch ? bodyMatch[1] : '';

// Extract head elements we need to preserve
const titleMatch = headContent.match(/<title>[^<]*<\/title>/);
const title = titleMatch ? titleMatch[0] : '<title>OSA Slides</title>';
const metaTags = headContent.match(/<meta[^>]*>/g) || [];
const linkTags = headContent.match(/<link[^>]*>/g) || [];
const otherHead = headContent
  .replace(/<title>[^<]*<\/title>/g, '')
  .replace(/<meta[^>]*>/g, '')
  .replace(/<link[^>]*>/g, '')
  .trim();
---

<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <Fragment set:html={title} />
  {metaTags.map((tag: string) => <Fragment set:html={tag} />)}
  {linkTags.map((tag: string) => <Fragment set:html={tag} />)}
  <Fragment set:html={otherHead} />
</head>
<body>
  <Fragment set:html={bodyContent} />
</body>
</html>
