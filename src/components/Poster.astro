  }
</style>

<script>
  const POSTER_W = 84 * 96; // 8064
  const POSTER_H = 42 * 96; // 4032
  const MIN_ZOOM = 0.05;
  const MAX_ZOOM = 1.0;

  function fitToScreen() {
    const wrapper = document.getElementById('posterWrapper');
    const controls = document.getElementById('previewControls');
    const padding = 40;
    const controlsH = controls ? controls.offsetHeight : 60;
    const availW = Math.max(window.innerWidth - padding, 200);
    const availH = Math.max(window.innerHeight - padding - controlsH, 200);
    const scale = Math.min(availW / POSTER_W, availH / POSTER_H, 1);
    currentScale = Math.max(scale, MIN_ZOOM);
    applyZoom();
  }

  function fitWidth() {
    const padding = 40;
    const availW = Math.max(window.innerWidth - padding, 200);
    currentScale = Math.min(Math.max(availW / POSTER_W, MIN_ZOOM), MAX_ZOOM);
    applyZoom();
  }

  let currentScale = 0.22;

  function zoomIn() {
    currentScale = Math.min(currentScale * 1.2, MAX_ZOOM);
    applyZoom();
  }
  function zoomOut() {
    currentScale = Math.max(currentScale / 1.2, MIN_ZOOM);
    applyZoom();
  }
  function applyZoom() {
    const wrapper = document.getElementById('posterWrapper')!;
    const controlsH = document.getElementById('previewControls')?.offsetHeight ?? 60;
    const scaledH = POSTER_H * currentScale;
    const scaledW = POSTER_W * currentScale;
    wrapper.style.transformOrigin = 'top left';
    wrapper.style.transform = `scale(${currentScale})`;
    wrapper.style.left = `${Math.max((window.innerWidth - scaledW) / 2, 10)}px`;
    // If poster fits vertically, center it; otherwise align to top with padding
    if (scaledH + controlsH + 40 <= window.innerHeight) {
      wrapper.style.top = `${Math.max((window.innerHeight - scaledH - controlsH) / 2, 10)}px`;
    } else {
      wrapper.style.top = '10px';
    }
    document.getElementById('zoomLevel')!.textContent = Math.round(currentScale * 100) + '%';
  }

  function resetZoom() {
    fitWidth();
  }

  (window as any).zoomIn = zoomIn;
  (window as any).zoomOut = zoomOut;
  (window as any).fitToScreen = fitToScreen;
  (window as any).resetZoom = resetZoom;

  window.addEventListener('load', () => { requestAnimationFrame(fitWidth); });
  window.addEventListener('resize', () => { requestAnimationFrame(fitWidth); });
</script>
