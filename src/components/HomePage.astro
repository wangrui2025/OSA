---
import Layout from '../layouts/Layout.astro';
import Section from './Section.astro';
import ActionButton from './ActionButton.astro';
import CopyButton from './CopyButton.astro';
import { getScholarlyArticleSchema } from '../utils/structuredData';
import { t } from '../i18n';
import { Image } from 'astro:assets';
import figOverview from '../assets/paper/fig/Met/fig_overview.png';
import figChallenge from '../assets/paper/fig/challenge/image.png';
import figOsu from '../assets/paper/fig/osu/fig_osu.png';
import figApfe from '../assets/paper/fig/apfe/fig_apfe.png';
import tabCap from '../assets/paper/tab/tab_cap.png';
import tabAbl from '../assets/paper/tab/tab_abl.png';
import figExp from '../assets/paper/fig/Exp/image.png';

interface Props {
  lang: 'en' | 'zh';
}

const { lang } = Astro.props;

const schema = getScholarlyArticleSchema({
  title: t(lang, 'publicationTitle'),
  authors: ['Rui Wang', 'Huisi Wu', 'Jing Qin'],
  description: t(lang, 'description'),
  url: new URL(Astro.url.pathname, Astro.site).href,
  image: new URL(`${import.meta.env.BASE_URL}/paper/fig/Met/fig_overview.png`, Astro.site).href,
  datePublished: '2026-06-01',
  venue: 'CVPR 2026',
  pdfUrl: 'https://arxiv.org/abs/2603.26188',
  codeUrl: 'https://github.com/wangrui2025/OSA',
});
---

<Layout title={t(lang, 'title')} description={t(lang, 'description')} lang={lang} structuredData={schema}>
  <!-- Hero -->
  <section class="relative pt-12 pb-16 md:pt-16 md:pb-20">
    <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center">
        <!-- Venue Badge -->
        <div class="mb-6">
          <span class="venue-badge">{t(lang, 'venue')}</span>
        </div>

        <h1 class="publication-title">
          {t(lang, 'publicationTitle')}
        </h1>

        <p class="text-lg mt-4 text-text-muted dark:text-text-muted-dark">
          {t(lang, 'venueFull')}
        </p>

        <div class="text-lg mt-6 font-medium">
          <span class="mx-1">Rui Wang<sup>1</sup>,</span>
          <span class="mx-1">Huisi Wu<sup>1,*</sup>,</span>
          <span class="mx-1">Jing Qin<sup>2</sup></span>
        </div>

        <div class="text-sm mt-3 text-text-muted dark:text-text-muted-dark">
          <div><sup>1</sup>{t(lang, 'affiliation1')}</div>
          <div><sup>2</sup>{t(lang, 'affiliation2')}</div>
        </div>

        <div class="flex flex-wrap justify-center gap-3 mt-8">
          <ActionButton href="https://arxiv.org/abs/2603.26188" icon="lucide:file-text" target="_blank">
            {t(lang, 'arxivLabel')}
          </ActionButton>
          <ActionButton href="https://github.com/wangrui2025/OSA" icon="lucide:github" target="_blank">
            {t(lang, 'codeLabel')}
          </ActionButton>
        </div>
      </div>
    </div>
  </section>

  <!-- Architecture Overview -->
  <Section>
    <div class="figure-card">
      <Image
        src={figOverview}
        alt="OSA Architecture Overview"
        width={1200}
        height={600}
        loading="eager"
      />
    </div>
    <p class="figure-caption mt-2">
      <strong>Figure 1.</strong> {t(lang, 'fig1Caption')}
    </p>
  </Section>

  <!-- Abstract -->
  <Section>
    <div class="abstract-box">
      <h2 class="section-heading text-center">{t(lang, 'abstractTitle')}</h2>
      <div class="prose dark:prose-invert max-w-none space-y-4">
        <p>{t(lang, 'abstractP1')}</p>
        <p>{t(lang, 'abstractP2')}</p>
        {t(lang, 'abstractP3') && <p>{t(lang, 'abstractP3')}</p>}
        {t(lang, 'abstractP4') && <p>{t(lang, 'abstractP4')}</p>}
      </div>
    </div>
  </Section>

  <!-- Motivation / Challenges -->
  <Section>
    <h2 class="section-heading">{t(lang, 'motivationTitle')}</h2>
    <p class="text-text-muted dark:text-text-muted-dark mb-8">{t(lang, 'motivationDesc')}</p>

    <div class="figure-card">
      <Image
        src={figChallenge}
        alt="Challenges in echocardiography segmentation"
        width={1200}
        height={400}
        loading="lazy"
      />
    </div>
    <p class="figure-caption mt-2">
      <strong>Figure 2.</strong> {t(lang, 'fig2Caption')}
    </p>
  </Section>

  <!-- Method -->
  <Section>
    <h2 class="section-heading">{t(lang, 'methodTitle')}</h2>

    <!-- OSU -->
    <div class="mb-12">
      <h3 class="text-xl font-semibold mb-4 text-text dark:text-text-dark">{t(lang, 'methodOsuTitle')}</h3>
      <p class="text-text-muted dark:text-text-muted-dark mb-6">{t(lang, 'methodOsuDesc')}</p>
      <div class="figure-card">
        <Image
          src={figOsu}
          alt="Orthogonalized State Update mechanism"
          width={1200}
          height={500}
          loading="lazy"
        />
      </div>
    </div>

    <!-- APFE -->
    <div class="mb-8">
      <h3 class="text-xl font-semibold mb-4 text-text dark:text-text-dark">{t(lang, 'methodApfeTitle')}</h3>
      <p class="text-text-muted dark:text-text-muted-dark mb-6">{t(lang, 'methodApfeDesc')}</p>
      <div class="figure-card">
        <Image
          src={figApfe}
          alt="Anatomical Prior-aware Feature Enhancement module"
          width={1200}
          height={500}
          loading="lazy"
        />
      </div>
    </div>

    <p class="figure-caption mt-2">
      <strong>Figure 3.</strong> {t(lang, 'fig3Caption')}
    </p>
  </Section>

  <!-- Results -->
  <Section>
    <h2 class="section-heading">{t(lang, 'resultsTitle')}</h2>
    <p class="text-text-muted dark:text-text-muted-dark mb-8">{t(lang, 'resultsDesc')}</p>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <!-- Quantitative Results Table -->
      <div class="figure-card">
        <Image
          src={tabCap}
          alt="Comparison with state-of-the-art methods"
          width={600}
          height={400}
          loading="lazy"
        />
        <p class="figure-caption">
          <strong>Table 1.</strong> {t(lang, 'table1Caption')}
        </p>
      </div>

      <!-- Ablation Study -->
      <div class="figure-card">
        <Image
          src={tabAbl}
          alt="Ablation study results"
          width={600}
          height={400}
          loading="lazy"
        />
        <p class="figure-caption">
          <strong>Table 2.</strong> {t(lang, 'table2Caption')}
        </p>
      </div>
    </div>

    <!-- Qualitative Results -->
    <div class="figure-card">
      <Image
        src={figExp}
        alt="Qualitative segmentation results"
        width={1200}
        height={500}
        loading="lazy"
      />
      <p class="figure-caption">
        <strong>Figure 4.</strong> {t(lang, 'fig4Caption')}
      </p>
    </div>
  </Section>

  <!-- BibTeX -->
  <Section id="bibtex">
    <h2 class="section-heading">{t(lang, 'bibtexTitle')}</h2>
    <div class="relative">
      <CopyButton targetId="bibtex-content" label={t(lang, 'copyLabel')} successLabel={t(lang, 'copiedLabel')} />
      <pre><code id="bibtex-content">{t(lang, 'bibtexEntry')}</code></pre>
    </div>
  </Section>

  <!-- Resources -->
  <Section class="pb-8">
    <div class="text-center">
      <h2 class="section-heading inline-block">{t(lang, 'resourcesTitle')}</h2>
      <div class="flex flex-wrap justify-center gap-3 mt-6">
        <ActionButton href="https://arxiv.org/abs/2603.26188" icon="lucide:file-text" target="_blank">
          {t(lang, 'arxivLabel')}
        </ActionButton>
        <ActionButton href="https://github.com/wangrui2025/OSA" icon="lucide:github" target="_blank">
          {t(lang, 'codeLabel')}
        </ActionButton>
        <ActionButton href={`${import.meta.env.BASE_URL}${lang}/poster`} icon="lucide:presentation">
          {t(lang, 'posterLabel')}
        </ActionButton>
        <ActionButton href={`${import.meta.env.BASE_URL}${lang}/slides`} icon="lucide:monitor">
          {t(lang, 'slidesLabel')}
        </ActionButton>
      </div>
    </div>
  </Section>
</Layout>
