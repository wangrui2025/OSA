---
import { ClientRouter } from 'astro:transitions';
import ThemeToggle from '../components/ThemeToggle.astro';
import LangSwitcher from '../components/LangSwitcher.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
  showFooter?: boolean;
  lang: 'en' | 'zh';
  structuredData?: Record<string, unknown>;
}

const {
  title,
  description = 'OSA: Echocardiography Video Segmentation via Orthogonalized State Update and Anatomical Prior-aware Feature Enhancement',
  image,
  showFooter = true,
  lang,
  structuredData,
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = image ?? new URL(`${import.meta.env.BASE_URL}/paper/fig/Met/fig_overview.png`, Astro.site).href;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title}</title>
    <meta name="description" content={description}>
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700&display=swap" as="style">
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Plus+Jakarta+Sans:wght@600;700&display=swap">

    <!-- FOUC Prevention -->
    <style>
      :root {
        --bg-color: #fafaf9;
        --text-color: #1e293b;
      }
      html.dark {
        --bg-color: #0a0a0a;
        --text-color: #f1f5f9;
      }
      html {
        background-color: var(--bg-color);
        color: var(--text-color);
      }
      body {
        margin: 0;
        min-height: 100vh;
      }
    </style>
    <script is:inline>
      (function () {
        function applyTheme() {
          const theme =
            localStorage.getItem('theme') ||
            (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
          document.documentElement.classList.toggle('dark', theme === 'dark');
          const meta = document.querySelector('meta[name="theme-color"]');
          if (meta) meta.setAttribute('content', theme === 'dark' ? '#0a0a0a' : '#fafaf9');
        }
        applyTheme();
        document.addEventListener('astro:after-swap', applyTheme);
      })();
    </script>

    <!-- SEO -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="canonical" href={canonicalUrl} />
    <meta name="theme-color" content="#fafaf9" />

    <!-- Icons -->
    <link rel="icon" type="image/png" href={`${import.meta.env.BASE_URL}/favicon.png`} />

    {structuredData && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    )}

    <!-- Client Router -->
    <ClientRouter fallback="none" />
  </head>

  <body class="min-h-screen flex flex-col">
    <!-- Top-right controls -->
    <div class="fixed top-4 right-4 z-50 flex items-center gap-2 bg-surface/80 dark:bg-surface-dark/80 backdrop-blur-sm rounded-lg p-1 border border-border dark:border-border-dark">
      <ThemeToggle />
      <LangSwitcher currentLang={lang} />
    </div>

    <main class="flex-1">
      <slot />
    </main>

    {showFooter && <Footer lang={lang} />}

    <!-- Event Delegation -->
    <script src="../../scripts/delegation.ts"></script>
  </body>
</html>
